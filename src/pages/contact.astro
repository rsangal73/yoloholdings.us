---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ContactForm from "../components/ContactForm.astro";
import ScrollReveal from "../components/ScrollReveal.tsx";
import { SITE } from "../config/site.mjs";
---

<Layout
  title={`Contact | ${SITE.title}`}
  description="Direct inquiries from institutional partners, commercial brokers, and fund managers to the Yolo Holdings LLC corporate desk."
  canonicalURL={`${SITE.url}/contact`}
>
  <Header />
  <main id="main-content" role="main">
    <section class="max-w-2xl mx-auto px-6 py-24">
      <ScrollReveal client:load>
        <p class="font-mono text-xs text-purple-400 uppercase tracking-widest mb-4">Corporate Desk</p>
        <h1 class="font-serif text-5xl text-slate-100 mb-4">Partner Inquiries</h1>
      </ScrollReveal>
      <ScrollReveal client:load delay={0.2}>
        <p class="text-slate-400 text-lg mb-12 leading-relaxed">
          Inquiries from institutional partners, commercial brokers, and fund managers
          can be directed to our corporate desk.
        </p>
      </ScrollReveal>
      <ScrollReveal client:load delay={0.3}>
        <ContactForm />
      </ScrollReveal>
    </section>
  </main>
  <Footer />
</Layout>
