---
import ScrollReveal from "./ScrollReveal.tsx";
---

<section class="max-w-6xl mx-auto px-6 pb-20">
  <ScrollReveal client:load scale={true}>
    <div class="border border-amber-400/20 bg-slate-800/40 p-10 md:p-14 rounded-sm">
      <div class="flex items-start gap-5">
        <div class="w-px shrink-0 self-stretch bg-amber-400/50 mt-1" aria-hidden="true"></div>
        <div>
          <p class="font-mono text-xs text-amber-400 uppercase tracking-widest mb-4">
            Accredited Investor Notice
          </p>
          <p class="text-slate-300 text-lg md:text-xl leading-relaxed max-w-3xl">
            Yolo Holdings LLC deploys capital strictly as an accredited investor and
            qualified purchaser. We do not solicit outside capital or offer public
            investment products.
          </p>
        </div>
      </div>
    </div>
  </ScrollReveal>
</section>
