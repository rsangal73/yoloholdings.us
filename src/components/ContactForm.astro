---
import { SITE } from "../config/site.mjs";

const web3formsAccessKey = SITE.web3formsAccessKey || "";
---

<form
  id="contact-form"
  class="space-y-5"
  aria-label="Contact form"
  novalidate
  action="https://api.web3forms.com/submit"
  method="POST"
>
  {web3formsAccessKey && (
    <input type="hidden" name="access_key" value={web3formsAccessKey} />
  )}
  <input type="hidden" name="subject" value="New Inquiry — Yolo Holdings LLC" />
  <input type="hidden" name="redirect" value="false" />
  <input type="checkbox" name="botcheck" class="hidden" style="display: none;" tabindex="-1" autocomplete="off" />

  <div
    id="success-message"
    class="hidden p-4 border border-amber-400/30 bg-amber-400/5 rounded-sm text-amber-400"
    role="alert"
    aria-live="polite"
  >
    <p class="font-mono text-sm">Inquiry received. We will be in touch.</p>
  </div>

  <div
    id="error-message"
    class="hidden p-4 border border-red-500/30 bg-red-500/5 rounded-sm text-red-400"
    role="alert"
    aria-live="assertive"
  >
    <p class="font-mono text-sm" id="error-text"></p>
  </div>

  <!-- Name -->
  <div>
    <label for="name" class="block font-mono text-xs text-slate-400 uppercase tracking-wider mb-2">
      Name <span class="text-amber-400/70" aria-label="required">*</span>
    </label>
    <input
      type="text"
      id="name"
      name="from_name"
      class="w-full px-4 py-3 bg-slate-800/60 border border-slate-700 text-slate-100 placeholder-slate-600 focus:outline-none focus:border-amber-400/60 transition-colors rounded-sm text-sm"
      required
      aria-required="true"
      aria-describedby="name-error"
      autocomplete="name"
    />
    <span id="name-error" class="mt-1 font-mono text-xs text-red-400 hidden" role="alert" aria-live="polite"></span>
  </div>

  <!-- Organization -->
  <div>
    <label for="organization" class="block font-mono text-xs text-slate-400 uppercase tracking-wider mb-2">
      Organization <span class="text-amber-400/70" aria-label="required">*</span>
    </label>
    <input
      type="text"
      id="organization"
      name="organization"
      class="w-full px-4 py-3 bg-slate-800/60 border border-slate-700 text-slate-100 placeholder-slate-600 focus:outline-none focus:border-amber-400/60 transition-colors rounded-sm text-sm"
      required
      aria-required="true"
      aria-describedby="org-error"
      autocomplete="organization"
    />
    <span id="org-error" class="mt-1 font-mono text-xs text-red-400 hidden" role="alert" aria-live="polite"></span>
  </div>

  <!-- Email -->
  <div>
    <label for="email" class="block font-mono text-xs text-slate-400 uppercase tracking-wider mb-2">
      Email <span class="text-amber-400/70" aria-label="required">*</span>
    </label>
    <input
      type="email"
      id="email"
      name="email"
      class="w-full px-4 py-3 bg-slate-800/60 border border-slate-700 text-slate-100 placeholder-slate-600 focus:outline-none focus:border-amber-400/60 transition-colors rounded-sm text-sm"
      required
      aria-required="true"
      aria-describedby="email-error"
      autocomplete="email"
    />
    <span id="email-error" class="mt-1 font-mono text-xs text-red-400 hidden" role="alert" aria-live="polite"></span>
  </div>

  <!-- Phone -->
  <div>
    <label for="phone" class="block font-mono text-xs text-slate-400 uppercase tracking-wider mb-2">
      Phone
    </label>
    <input
      type="tel"
      id="phone"
      name="phone"
      class="w-full px-4 py-3 bg-slate-800/60 border border-slate-700 text-slate-100 placeholder-slate-600 focus:outline-none focus:border-amber-400/60 transition-colors rounded-sm text-sm"
      aria-describedby="phone-error"
      autocomplete="tel"
    />
    <span id="phone-error" class="mt-1 font-mono text-xs text-red-400 hidden" role="alert" aria-live="polite"></span>
  </div>

  <!-- Message -->
  <div>
    <label for="message" class="block font-mono text-xs text-slate-400 uppercase tracking-wider mb-2">
      Message <span class="text-amber-400/70" aria-label="required">*</span>
    </label>
    <textarea
      id="message"
      name="message"
      rows="5"
      class="w-full px-4 py-3 bg-slate-800/60 border border-slate-700 text-slate-100 placeholder-slate-600 focus:outline-none focus:border-amber-400/60 transition-colors rounded-sm text-sm resize-none"
      required
      aria-required="true"
      aria-describedby="message-error"
    ></textarea>
    <span id="message-error" class="mt-1 font-mono text-xs text-red-400 hidden" role="alert" aria-live="polite"></span>
  </div>

  <button
    type="submit"
    id="submit-button"
    class="w-full px-6 py-3 border border-amber-400/40 text-amber-400 hover:bg-amber-400/10 transition-colors font-mono text-sm uppercase tracking-widest rounded-sm disabled:opacity-40 disabled:cursor-not-allowed"
  >
    <span id="submit-text">Send Inquiry</span>
    <span id="submit-loading" class="hidden">Sending...</span>
  </button>
</form>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const submitButton = document.getElementById("submit-button") as HTMLButtonElement;
  const submitText = document.getElementById("submit-text") as HTMLSpanElement;
  const submitLoading = document.getElementById("submit-loading") as HTMLSpanElement;
  const successMessage = document.getElementById("success-message") as HTMLDivElement;
  const errorMessage = document.getElementById("error-message") as HTMLDivElement;
  const errorText = document.getElementById("error-text") as HTMLParagraphElement;

  const nameInput = document.getElementById("name") as HTMLInputElement;
  const orgInput = document.getElementById("organization") as HTMLInputElement;
  const emailInput = document.getElementById("email") as HTMLInputElement;
  const phoneInput = document.getElementById("phone") as HTMLInputElement;
  const messageInput = document.getElementById("message") as HTMLTextAreaElement;
  const nameError = document.getElementById("name-error") as HTMLSpanElement;
  const orgError = document.getElementById("org-error") as HTMLSpanElement;
  const emailError = document.getElementById("email-error") as HTMLSpanElement;
  const messageError = document.getElementById("message-error") as HTMLSpanElement;

  function showFieldError(field: HTMLInputElement | HTMLTextAreaElement, errorEl: HTMLSpanElement, msg: string) {
    field.setAttribute("aria-invalid", "true");
    field.classList.add("border-red-500/60");
    errorEl.textContent = msg;
    errorEl.classList.remove("hidden");
  }

  function clearFieldError(field: HTMLInputElement | HTMLTextAreaElement, errorEl: HTMLSpanElement) {
    field.removeAttribute("aria-invalid");
    field.classList.remove("border-red-500/60");
    errorEl.classList.add("hidden");
    errorEl.textContent = "";
  }

  function setLoading(loading: boolean) {
    submitButton.disabled = loading;
    submitText.classList.toggle("hidden", loading);
    submitLoading.classList.toggle("hidden", !loading);
  }

  nameInput.addEventListener("blur", () => {
    const v = nameInput.value.trim();
    if (!v) showFieldError(nameInput, nameError, "Name is required");
    else if (v.length < 2) showFieldError(nameInput, nameError, "Name must be at least 2 characters");
    else clearFieldError(nameInput, nameError);
  });

  orgInput.addEventListener("blur", () => {
    const v = orgInput.value.trim();
    if (!v) showFieldError(orgInput, orgError, "Organization is required");
    else clearFieldError(orgInput, orgError);
  });

  emailInput.addEventListener("blur", () => {
    const v = emailInput.value.trim();
    if (!v) showFieldError(emailInput, emailError, "Email is required");
    else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v)) showFieldError(emailInput, emailError, "Please enter a valid email");
    else clearFieldError(emailInput, emailError);
  });

  messageInput.addEventListener("blur", () => {
    const v = messageInput.value.trim();
    if (!v) showFieldError(messageInput, messageError, "Message is required");
    else if (v.length < 10) showFieldError(messageInput, messageError, "Message must be at least 10 characters");
    else clearFieldError(messageInput, messageError);
  });

  const accessKeyInput = form.querySelector('input[name="access_key"]') as HTMLInputElement;
  const hasAccessKey = accessKeyInput && accessKeyInput.value.trim() !== "";

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    successMessage.classList.add("hidden");
    errorMessage.classList.add("hidden");

    if (!hasAccessKey) {
      errorText.textContent = "Form is not configured. Please contact the site administrator.";
      errorMessage.classList.remove("hidden");
      return;
    }

    clearFieldError(nameInput, nameError);
    clearFieldError(orgInput, orgError);
    clearFieldError(emailInput, emailError);
    clearFieldError(messageInput, messageError);

    let isValid = true;

    if (!nameInput.value.trim()) {
      showFieldError(nameInput, nameError, "Name is required");
      isValid = false;
    }
    if (!orgInput.value.trim()) {
      showFieldError(orgInput, orgError, "Organization is required");
      isValid = false;
    }
    const emailVal = emailInput.value.trim();
    if (!emailVal) {
      showFieldError(emailInput, emailError, "Email is required");
      isValid = false;
    } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailVal)) {
      showFieldError(emailInput, emailError, "Please enter a valid email");
      isValid = false;
    }
    if (!messageInput.value.trim()) {
      showFieldError(messageInput, messageError, "Message is required");
      isValid = false;
    } else if (messageInput.value.trim().length < 10) {
      showFieldError(messageInput, messageError, "Message must be at least 10 characters");
      isValid = false;
    }

    if (!isValid) {
      const firstError = form.querySelector('[aria-invalid="true"]') as HTMLElement;
      if (firstError) firstError.focus();
      return;
    }

    setLoading(true);

    try {
      const response = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        body: new FormData(form),
      });
      const data = await response.json();

      if (response.ok && data.success) {
        successMessage.classList.remove("hidden");
        form.reset();
        successMessage.scrollIntoView({ behavior: "smooth", block: "nearest" });
      } else {
        errorText.textContent = data.message || "Failed to send inquiry. Please try again.";
        errorMessage.classList.remove("hidden");
        errorMessage.scrollIntoView({ behavior: "smooth", block: "nearest" });
      }
    } catch {
      errorText.textContent = "Network error. Please check your connection and try again.";
      errorMessage.classList.remove("hidden");
      errorMessage.scrollIntoView({ behavior: "smooth", block: "nearest" });
    } finally {
      setLoading(false);
    }
  });
</script>
