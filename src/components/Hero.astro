---
import ScrollReveal from "./ScrollReveal.tsx";
---

<section
  id="overview"
  class="relative min-h-screen flex items-center bg-slate-900 hero-grid overflow-hidden"
  aria-labelledby="hero-heading"
>
  <!-- Radial glow overlay -->
  <div class="absolute inset-0 hero-glow pointer-events-none" aria-hidden="true"></div>

  <!-- Decorative corner lines -->
  <div class="absolute top-12 left-12 w-16 h-16 border-l border-t border-purple-400/20 pointer-events-none hidden lg:block" aria-hidden="true"></div>
  <div class="absolute bottom-12 right-12 w-16 h-16 border-r border-b border-purple-400/20 pointer-events-none hidden lg:block" aria-hidden="true"></div>

  <div class="relative max-w-5xl mx-auto px-6 py-32 text-center w-full">
    <ScrollReveal client:load>
      <p class="font-mono text-xs text-purple-400 uppercase tracking-widest mb-8">
        Private Investment Vehicle
      </p>
    </ScrollReveal>

    <ScrollReveal client:load delay={0.15}>
      <h1
        id="hero-heading"
        class="font-serif text-5xl md:text-7xl lg:text-8xl text-slate-100 leading-tight mb-8"
      >
        Private Capital.<br />
        <span class="text-slate-300">Long-Term Vision.</span>
      </h1>
    </ScrollReveal>

    <ScrollReveal client:load delay={0.25}>
      <div class="w-16 h-px bg-purple-400 mx-auto mb-8" aria-hidden="true"></div>
    </ScrollReveal>

    <ScrollReveal client:load delay={0.35}>
      <p class="text-slate-400 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed mb-14">
        Yolo Holdings LLC is a private investment vehicle specializing in
        commercial real estate acquisition, strategic fund placement, and private equity
        allocations.
      </p>
    </ScrollReveal>

    <ScrollReveal client:load delay={0.45}>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="#investment-focus"
          class="inline-block px-8 py-3 border border-slate-600 text-slate-300 hover:border-purple-400/60 hover:text-purple-400 transition-colors text-sm font-mono uppercase tracking-widest rounded-sm"
        >
          Investment Focus
        </a>
        <a
          href="#contact"
          class="inline-block px-8 py-3 bg-purple-400/10 border border-purple-400/40 text-purple-400 hover:bg-purple-400/20 transition-colors text-sm font-mono uppercase tracking-widest rounded-sm"
        >
          Partner Inquiries
        </a>
      </div>
    </ScrollReveal>
  </div>
</section>
