---
import ScrollReveal from "./ScrollReveal.tsx";
import { Icon } from "astro-icon/components";
---

<section id="investment-focus" class="max-w-6xl mx-auto px-6 py-28">
  <ScrollReveal client:load delay={0.1}>
    <div class="mb-16 text-center">
      <p class="font-mono text-xs text-purple-400 uppercase tracking-widest mb-4">
        Capital Deployment
      </p>
      <h2 class="font-serif text-4xl md:text-5xl text-slate-100">
        Investment Focus
      </h2>
    </div>
  </ScrollReveal>

  <div class="grid md:grid-cols-2 gap-6">
    <ScrollReveal client:load delay={0.2} scale={true}>
      <div class="group p-8 bg-slate-800/60 border border-slate-700 hover:border-purple-400/40 transition-all duration-300 rounded-sm h-full">
        <div class="w-10 h-10 border border-purple-400/40 group-hover:border-purple-400/70 flex items-center justify-center mb-6 transition-colors">
          <Icon name="tabler:building-skyscraper" class="w-5 h-5 text-purple-400" aria-hidden="true" />
        </div>
        <h3 class="font-serif text-xl text-slate-100 mb-3">Commercial Real Estate</h3>
        <p class="text-slate-400 leading-relaxed text-sm">
          Strategic acquisition of stable, income-generating assets with a focus on
          long-term value creation.
        </p>
      </div>
    </ScrollReveal>

    <ScrollReveal client:load delay={0.3} scale={true}>
      <div class="group p-8 bg-slate-800/60 border border-slate-700 hover:border-purple-400/40 transition-all duration-300 rounded-sm h-full">
        <div class="w-10 h-10 border border-purple-400/40 group-hover:border-purple-400/70 flex items-center justify-center mb-6 transition-colors">
          <Icon name="tabler:file-certificate" class="w-5 h-5 text-purple-400" aria-hidden="true" />
        </div>
        <h3 class="font-serif text-xl text-slate-100 mb-3">Net Lease (NNN) Portfolio</h3>
        <p class="text-slate-400 leading-relaxed text-sm">
          Management of institutional-grade, triple-net leased commercial properties
          ensuring stable tenant relationships.
        </p>
      </div>
    </ScrollReveal>

    <ScrollReveal client:load delay={0.4} scale={true}>
      <div class="group p-8 bg-slate-800/60 border border-slate-700 hover:border-purple-400/40 transition-all duration-300 rounded-sm h-full">
        <div class="w-10 h-10 border border-purple-400/40 group-hover:border-purple-400/70 flex items-center justify-center mb-6 transition-colors">
          <Icon name="tabler:home-2" class="w-5 h-5 text-purple-400" aria-hidden="true" />
        </div>
        <h3 class="font-serif text-xl text-slate-100 mb-3">Specialized Communities</h3>
        <p class="text-slate-400 leading-relaxed text-sm">
          Capital allocation in manufactured housing communities and niche real estate
          asset classes.
        </p>
      </div>
    </ScrollReveal>

    <ScrollReveal client:load delay={0.5} scale={true}>
      <div class="group p-8 bg-slate-800/60 border border-slate-700 hover:border-purple-400/40 transition-all duration-300 rounded-sm h-full">
        <div class="w-10 h-10 border border-purple-400/40 group-hover:border-purple-400/70 flex items-center justify-center mb-6 transition-colors">
          <Icon name="tabler:chart-line" class="w-5 h-5 text-purple-400" aria-hidden="true" />
        </div>
        <h3 class="font-serif text-xl text-slate-100 mb-3">Private Placements & Funds</h3>
        <p class="text-slate-400 leading-relaxed text-sm">
          Passive general partner and limited partner commitments alongside premier real
          estate and venture funds.
        </p>
      </div>
    </ScrollReveal>
  </div>

  <ScrollReveal client:load delay={0.6}>
    <div class="mt-20 border-t border-slate-800 pt-16 grid md:grid-cols-3 gap-10 text-sm text-slate-400 leading-relaxed">
      <div>
        <h3 class="font-serif text-slate-200 text-base mb-3">Private Lending & Real Estate Debt</h3>
        <p>
          Yolo Holdings deploys capital across private lending strategies including bridge loans,
          construction financing, and real estate debt instruments. Our private debt allocations
          target short-duration, asset-backed opportunities with institutional-quality underwriting.
        </p>
      </div>
      <div>
        <h3 class="font-serif text-slate-200 text-base mb-3">NNN & Income Real Estate</h3>
        <p>
          We acquire and manage triple-net lease (NNN) commercial properties, net-leased retail,
          and other income-producing real estate assets. Our portfolio strategy emphasizes stable
          cash flow, long-term tenant credit quality, and geographic diversification.
        </p>
      </div>
      <div>
        <h3 class="font-serif text-slate-200 text-base mb-3">Private Placements & Syndications</h3>
        <p>
          As an accredited investor and qualified purchaser, Yolo Holdings participates in private
          placements, real estate syndications, hard money lending pools, mezzanine financing
          structures, and select venture and growth equity funds.
        </p>
      </div>
    </div>
  </ScrollReveal>
</section>
