---
import { Icon } from "astro-icon/components";
---

<header
  class="w-full py-5 px-4 border-b border-slate-800 bg-slate-900/95 backdrop-blur-sm sticky top-0 z-50"
  role="banner"
>
  <nav
    class="max-w-6xl mx-auto flex items-center justify-between"
    aria-label="Main navigation"
  >
    <a
      href="/"
      class="font-serif text-xl font-semibold text-slate-100 hover:text-purple-400 transition-colors tracking-wide"
      aria-label="Yolo Holdings LLC - Home"
    >
      Yolo Holdings LLC
    </a>

    <!-- Mobile menu button -->
    <button
      type="button"
      class="md:hidden p-2 text-slate-400 hover:text-purple-400 focus:outline-none focus:ring-1 focus:ring-purple-400/50 rounded"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      id="mobile-menu-button"
    >
      <Icon name="tabler:menu-2" class="w-5 h-5" aria-hidden="true" />
    </button>

    <!-- Desktop navigation -->
    <ul class="hidden md:flex items-center gap-8" role="list">
      <li>
        <a
          href="#overview"
          class="text-sm text-slate-400 hover:text-purple-400 transition-colors tracking-wide uppercase font-mono"
        >
          Overview
        </a>
      </li>
      <li>
        <a
          href="#investment-focus"
          class="text-sm text-slate-400 hover:text-purple-400 transition-colors tracking-wide uppercase font-mono"
        >
          Investment Focus
        </a>
      </li>
      <li>
        <a
          href="#contact"
          class="text-sm px-5 py-2 border border-purple-400/40 text-purple-400 hover:bg-purple-400/10 transition-colors tracking-wide uppercase font-mono rounded-sm"
        >
          Contact
        </a>
      </li>
    </ul>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-slate-800 bg-slate-900 mt-4"
    role="menu"
    aria-labelledby="mobile-menu-button"
  >
    <ul class="flex flex-col py-4" role="list">
      <li>
        <a
          href="#overview"
          class="block px-4 py-3 text-sm text-slate-400 hover:text-purple-400 hover:bg-slate-800/50 transition-colors uppercase tracking-wide font-mono"
          role="menuitem"
        >
          Overview
        </a>
      </li>
      <li>
        <a
          href="#investment-focus"
          class="block px-4 py-3 text-sm text-slate-400 hover:text-purple-400 hover:bg-slate-800/50 transition-colors uppercase tracking-wide font-mono"
          role="menuitem"
        >
          Investment Focus
        </a>
      </li>
      <li>
        <a
          href="#contact"
          class="block px-4 py-3 text-sm text-purple-400 hover:bg-slate-800/50 transition-colors uppercase tracking-wide font-mono"
          role="menuitem"
        >
          Contact
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const menuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');

  if (menuButton && mobileMenu) {
    menuButton.addEventListener('click', () => {
      const isExpanded = menuButton.getAttribute('aria-expanded') === 'true';
      menuButton.setAttribute('aria-expanded', String(!isExpanded));
      mobileMenu.classList.toggle('hidden');
    });

    document.addEventListener('click', (e) => {
      if (
        !menuButton.contains(e.target as Node) &&
        !mobileMenu.contains(e.target as Node) &&
        !mobileMenu.classList.contains('hidden')
      ) {
        menuButton.setAttribute('aria-expanded', 'false');
        mobileMenu.classList.add('hidden');
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !mobileMenu.classList.contains('hidden')) {
        menuButton.setAttribute('aria-expanded', 'false');
        mobileMenu.classList.add('hidden');
        menuButton.focus();
      }
    });
  }
</script>
